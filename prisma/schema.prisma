// DAFLOW — schema de base de datos
// Ver daflow-especificacion.md para el modelo de negocio completo.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/* ---------------- Configuración global de la plataforma ---------------- */
model PlatformSettings {
  id                String    @id @default("singleton")
  adminPasswordHash String
  adminEmail        String?
  logoUrl           String?
  // Marca de agua opcional (logo + wordmark) mostrada discretamente en la tarjeta de Inicio.
  bannerUrl         String?
  // Ícono de la pestaña del navegador — si no se sube uno, se usa el /icon.svg genérico por defecto.
  faviconUrl        String?
  // Cumpleaños del admin — el único perfil sin un User real detrás, así que
  // vive aquí en vez de en la tabla User.
  adminBirthDate    DateTime?
  updatedAt         DateTime  @updatedAt
}

// Token temporal para el flujo de "olvidé mi contraseña" del administrador
model PasswordResetToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
}

/* ---------------- Áreas del negocio ---------------- */
model Department {
  id         String   @id @default(cuid())
  name       String
  code       String   @unique
  order      Int      @default(0)
  // Áreas especiales (ej. proyectos confidenciales) se anclan aparte en el menú,
  // no se mezclan con la lista arrastrable de áreas normales del negocio.
  isSpecial  Boolean  @default(false)
  // Habilita la pestaña de KPIs financieros (ROI, ventas y ganancia mensual) para esta área.
  trackKpis  Boolean  @default(false)
  // Habilita el registro semanal (ej. pedidos despachados) que se muestra en el Inicio para todos.
  trackWeeklyMetric Boolean @default(false)
  // Habilita la bitácora de feedback semanal (reunión admin-líder): problemas y plan de acción.
  // Solo el admin puede escribir en ella; el área solo puede verla.
  trackWeeklyReview Boolean @default(false)
  // Habilita "Pagos recordatorios" (facturas/suscripciones mensuales que vencen en fechas
  // variables) — confirmado 2026-07-22: solo Finanzas y Contabilidad, por ahora.
  trackPaymentReminders Boolean @default(false)
  createdAt  DateTime @default(now())

  users        User[]
  processes    Process[]
  documents    Document[]
  exams        Exam[]
  leaders      User[]      @relation("DeptLeader")
  positions    Position[]
  financeOperations     FinanceOperation[]
  financeKpis           FinanceKpiRecord[]
  financeSharedBalances FinanceSharedMonthlyBalance[]
  financeKpiUploads     FinanceKpiUpload[]
  financeKpiSettings    FinanceKpiSettings?
  weeklyMetrics WeeklyMetricRecord[]
  weeklyReviews WeeklyReviewRecord[]
  paymentReminders      PaymentReminder[]

  @@index([order])
}

// Catálogo de puestos/cargos que el admin arma por área, para elegir al dar de alta a alguien
model Position {
  id     String     @id @default(cuid())
  deptId String
  dept   Department @relation(fields: [deptId], references: [id], onDelete: Cascade)
  name   String

  @@unique([deptId, name])
  @@index([deptId])
}

/* ---------------- Personas (nómina + acceso) ---------------- */
model User {
  id           String   @id @default(cuid())
  name         String
  username     String   @unique
  passwordHash String
  deptId       String?
  department   Department? @relation(fields: [deptId], references: [id], onDelete: SetNull)

  // Off = someone left the company: blocked from logging in (checked at
  // auth time and re-checked on every /area request in case they're already
  // logged in), and hidden from the org chart. Everything else about them —
  // Nómina profile, isLeader, historial — stays intact so reactivating them
  // restores exactly what they had before.
  isActive Boolean @default(true)

  photoUrl  String?
  position  String?
  email     String?
  phone     String?
  startDate DateTime?
  birthDate DateTime?
  skills    String[] @default([])
  cvUrl     String?
  cvName    String?

  isLeader    Boolean     @default(false)
  leadsDeptId String?
  leadsDept   Department? @relation("DeptLeader", fields: [leadsDeptId], references: [id], onDelete: SetNull)

  // Puede crear/editar documentos en "Leyes y Reglamentos" (visibles para toda la empresa), pero no eliminarlos.
  canManageLaws Boolean @default(false)

  // Puede proponer proveedores nuevos (quedan "Pendiente" hasta que su líder los apruebe). No puede editar ni eliminar.
  canAddSuppliers Boolean @default(false)

  // Última vez que este usuario (como líder) revisó el Feedback semanal de su área — usado para el
  // contador de "sin leer" en el sidebar. Null = nunca lo ha visto.
  lastSeenFeedbackAt DateTime?

  // Última vez que este usuario revisó sus propios roles de pago — usado para el
  // contador de "sin leer" en el sidebar. Null = nunca lo ha visto.
  lastSeenPayStubAt DateTime?

  snoozeUntil DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  examScores    ExamScore[]
  milestones    Milestone[]
  ackUpdates    UserAckUpdate[]
  suppliersCreated  Supplier[] @relation("SupplierCreatedBy")
  suppliersApproved Supplier[] @relation("SupplierApprovedBy")
  payStubs         PayStub[] @relation("PayStubOwner")
  payStubsUploaded PayStub[] @relation("PayStubUploadedBy")
  financeKpiRecordsUploaded FinanceKpiRecord[] @relation("FinanceKpiRecordUploadedBy")
  financeKpiUploadsBy       FinanceKpiUpload[] @relation("FinanceKpiUploadUploadedBy")
  paymentReminderRecordsCompleted PaymentReminderRecord[] @relation("PaymentReminderCompletedBy")
  confidentialAccess ConfidentialDocumentAccess[]
  monthlyEvaluationsReceived MonthlyEvaluation[]
  monthlyRecognitionResults  MonthlyRecognitionResult[]
  monthlyEvaluationSummaries MonthlyEvaluationSummary[]

  @@index([deptId])
  @@index([leadsDeptId])
}

model Milestone {
  id     String   @id @default(cuid())
  userId String
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title  String
  note   String?
  date   DateTime @default(now())

  @@index([userId])
}

/* ---------------- Procesos (flujograma) ---------------- */
model Process {
  id          String  @id @default(cuid())
  deptId      String
  department  Department @relation(fields: [deptId], references: [id], onDelete: Cascade)
  title       String
  description String  @default("")
  sketchUrl   String?
  sketchName  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  flowSteps      FlowStep[]
  updates        ProcessUpdate[]

  @@index([deptId])
}

enum FlowStepType {
  START
  END
  PROCESS
  DECISION
  IO
  SUBPROCESS
  DOCUMENT
  PREPARE
  STORAGE
  CONNECTOR
  CHECKLIST
}

model FlowStep {
  id        String       @id @default(cuid())
  processId String
  process   Process      @relation(fields: [processId], references: [id], onDelete: Cascade)
  order     Int          @default(0)
  type      FlowStepType @default(PROCESS)
  label     String
  detail    String       @default("")

  // Solo para type = DOCUMENT: PDF adjunto al bloque
  fileUrl  String?
  fileName String?

  // React Flow canvas position, saved so the editor restores exact layout
  positionX Float @default(0)
  positionY Float @default(0)

  branches        FlowBranch[]            @relation("StepBranches")
  incomingBranch  FlowBranch[]            @relation("StepTarget")
  checklistItems  FlowStepChecklistItem[]

  @@index([processId])
}

// Solo para type = CHECKLIST: puntos de verificación propios de ese bloque del flujo
model FlowStepChecklistItem {
  id     String   @id @default(cuid())
  stepId String
  step   FlowStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
  text   String
  order  Int      @default(0)

  @@index([stepId])
}

model FlowBranch {
  id           String   @id @default(cuid())
  stepId       String
  step         FlowStep @relation("StepBranches", fields: [stepId], references: [id], onDelete: Cascade)
  label        String   @default("")
  targetStepId String?
  targetStep   FlowStep? @relation("StepTarget", fields: [targetStepId], references: [id], onDelete: SetNull)

  // Qué lado del símbolo se usó para dibujar la conexión (top/right/bottom/left)
  sourceHandle String?
  targetHandle String?

  @@index([stepId])
}

model ProcessUpdate {
  id        String   @id @default(cuid())
  processId String
  process   Process  @relation(fields: [processId], references: [id], onDelete: Cascade)
  // Qué cambió, para el historial visible del proceso — obligatorio al notificar.
  note      String   @default("")
  createdAt DateTime @default(now())

  acks UserAckUpdate[]

  @@index([processId])
}

model UserAckUpdate {
  userId   String
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  updateId String
  update   ProcessUpdate @relation(fields: [updateId], references: [id], onDelete: Cascade)
  ackedAt  DateTime      @default(now())

  @@id([userId, updateId])
}

/* ---------------- Documentos (por área, y Leyes y Reglamentos con deptId nulo) ---------------- */
model Document {
  id        String      @id @default(cuid())
  deptId    String?
  department Department? @relation(fields: [deptId], references: [id], onDelete: Cascade)
  isLaw     Boolean     @default(false)
  title     String
  content   String      @default("")
  link      String      @default("")
  fileUrl   String?
  fileName  String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([deptId])
  @@index([isLaw])
}

/* ---------------- Exámenes ---------------- */
model Exam {
  id        String   @id @default(cuid())
  deptId    String
  department Department @relation(fields: [deptId], references: [id], onDelete: Cascade)
  title     String
  createdAt DateTime @default(now())

  questions ExamQuestion[]
  scores    ExamScore[]

  @@index([deptId])
}

model ExamQuestion {
  id           String @id @default(cuid())
  examId       String
  exam         Exam   @relation(fields: [examId], references: [id], onDelete: Cascade)
  text         String
  options      String[]
  correctIndex Int
  order        Int    @default(0)

  @@index([examId])
}

model ExamScore {
  id        String   @id @default(cuid())
  examId    String
  exam      Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userName  String
  score     Int
  total     Int
  createdAt DateTime @default(now())

  @@index([examId])
  @@index([userId])
}

/* ---------------- KPIs financieros (histórico mensual por operación) ---------------- */
// Catálogo de operaciones/marcas dentro de un departamento (hoy solo lo usa
// Finanzas y Contabilidad): Provedix, Importadora Damián, e Importadora
// Shanghai (todavía inactiva). Activar una operación nueva es un simple
// UPDATE de isActive, no una migración.
model FinanceOperation {
  id         String     @id @default(cuid())
  deptId     String
  department Department @relation(fields: [deptId], references: [id], onDelete: Cascade)

  name     String
  isActive Boolean @default(true)
  order    Int     @default(0)

  createdAt DateTime @default(now())

  records FinanceKpiRecord[]

  @@unique([deptId, name])
  @@index([deptId])
}

// Un registro por operación por mes: los 7 datos crudos que arman el estado
// de resultados. Utilidad bruta/operativa/neta y márgenes se calculan
// siempre en el servidor a partir de estos campos — nunca se guardan acá —
// para no repetir el problema de fórmulas rotas del Excel original. ROI se
// captura directo, todavía sin un monto de inversión que lo derive.
model FinanceKpiRecord {
  id          String           @id @default(cuid())
  deptId      String
  department  Department       @relation(fields: [deptId], references: [id], onDelete: Cascade)
  operationId String
  operation   FinanceOperation @relation(fields: [operationId], references: [id], onDelete: Cascade)

  // Mes al que corresponde el registro, formato "YYYY-MM"
  period String

  ventas            Float
  costoVentas       Float
  gastosVenta       Float
  gastosAdmin       Float
  otrosIngresos     Float
  gastosFinancieros Float
  otrosGastos       Float
  roi               Float?

  // Quién subió/corrigió este registro por última vez — null si lo hizo el
  // admin directamente (su sesión no tiene un User real, igual que PayStub).
  uploadedById String?
  uploadedBy   User?   @relation("FinanceKpiRecordUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([operationId, period])
  @@index([deptId])
  @@index([operationId])
}

// Saldos compartidos de TODA la operación al cierre del mes — inventario,
// cuentas por cobrar y cuentas por pagar son de la empresa completa, no se
// reparten por marca (Provedix e Importadora Damián comparten bodega,
// cartera y proveedores). Alimentan días de inventario/cartera/proveedores
// y el ciclo de conversión de efectivo, siempre calculados en Consolidado.
model FinanceSharedMonthlyBalance {
  id         String     @id @default(cuid())
  deptId     String
  department Department @relation(fields: [deptId], references: [id], onDelete: Cascade)

  period String // "YYYY-MM"

  inventarioFinal  Float?
  cuentasPorCobrar Float?
  cuentasPorPagar  Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([deptId, period])
  @@index([deptId])
}

// Historial de cargas — quién subió qué mes y cuándo, y si reemplazó
// (corrigió) un mes que ya existía. Alimenta "Cargas recientes".
model FinanceKpiUpload {
  id         String     @id @default(cuid())
  deptId     String
  department Department @relation(fields: [deptId], references: [id], onDelete: Cascade)

  period String // "YYYY-MM"

  uploadedById String?
  uploadedBy   User?   @relation("FinanceKpiUploadUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)

  fileUrl  String?
  fileName String?

  // true si este mes ya tenía información y esta carga la reemplazó.
  isCorrection Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([deptId])
  @@index([period])
}

// Metas de margen, bandas de ROI, y tasa de impuesto — un registro por
// departamento, editable desde el dashboard (ej. el campito de tasa de
// impuesto). Valores por defecto ya confirmados por el admin para Finanzas
// y Contabilidad.
model FinanceKpiSettings {
  id         String     @id @default(cuid())
  deptId     String     @unique
  department Department @relation(fields: [deptId], references: [id], onDelete: Cascade)

  targetMargenBruto     Float @default(35)
  targetMargenOperativo Float @default(15)
  // Margen neto usa bandas absolutas propias (no un solo "target" relativo
  // como bruto/operativo): <targetMargenNeto alerta, hasta excelenteMargenNeto
  // saludable, por encima excelente.
  targetMargenNeto      Float @default(20)
  excelenteMargenNeto   Float @default(30)

  roiBandRed    Float @default(10)
  roiBandYellow Float @default(18)
  roiBandTarget Float @default(20)

  taxRatePct Float @default(25)

  updatedAt DateTime @updatedAt
}

// Pagos mensuales variados (suscripciones, servicios, tarjetas...) que se
// dan de alta/baja con el tiempo — confirmado 2026-07-22, solo Finanzas y
// Contabilidad por ahora. Sin monto de referencia a propósito: cada mes se
// ingresa manualmente el monto real al marcar "Realizado" (PaymentReminderRecord),
// porque los montos varían mes a mes.
model PaymentReminder {
  id         String     @id @default(cuid())
  deptId     String
  department Department @relation(fields: [deptId], references: [id], onDelete: Cascade)
  name       String // empresa/plataforma a la que se paga
  paymentMethod String?
  dueDay           Int // día del mes de vencimiento (1-31, se recorta al último día real del mes)
  reminderStartDay Int // día del mes desde el cual empieza a aparecer en pendientes
  isActive   Boolean  @default(true)
  order      Int      @default(0)
  createdAt  DateTime @default(now())

  records PaymentReminderRecord[]

  @@index([deptId])
}

model PaymentReminderRecord {
  id            String          @id @default(cuid())
  reminderId    String
  reminder      PaymentReminder @relation(fields: [reminderId], references: [id], onDelete: Cascade)
  period        String // "YYYY-MM"
  amountPaid    Float
  completedById String?
  completedBy   User?           @relation("PaymentReminderCompletedBy", fields: [completedById], references: [id], onDelete: SetNull)
  completedAt   DateTime        @default(now())

  @@unique([reminderId, period])
  @@index([reminderId])
}

/* ---------------- Métrica semanal (ej. pedidos despachados de Fulfillment) ---------------- */
model WeeklyMetricRecord {
  id         String     @id @default(cuid())
  deptId     String
  department Department @relation(fields: [deptId], references: [id], onDelete: Cascade)

  // Semana ISO, formato "YYYY-Www" (lo que entrega <input type="week">)
  week  String
  value Int

  // Pedidos que quedaron sin despachar esa semana (opcional), usado para
  // calcular el Fill Rate: value / (value + notDispatched) * 100.
  notDispatched Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([deptId, week])
  @@index([deptId])
}

enum ReviewStatus {
  PENDING
  RESOLVED
  REJECTED
}

/* ---------------- Feedback semanal (reunión admin-líder: problemas y plan de acción) ---------------- */
model WeeklyReviewRecord {
  id         String     @id @default(cuid())
  deptId     String
  department Department @relation(fields: [deptId], references: [id], onDelete: Cascade)

  // Semana ISO, formato "YYYY-Www" (lo que entrega <input type="week">)
  week       String
  problem    String
  actionPlan String
  status     ReviewStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([deptId])
}

enum SupplierStatus {
  PENDING
  APPROVED
  REJECTED
}

/* ---------------- Proveedores (directorio con aprobación del líder) ---------------- */
model Supplier {
  id          String  @id @default(cuid())
  name        String
  location    String?
  // Pin exacto marcado en el mapa (OpenStreetMap), opcional — más confiable que
  // una dirección escrita para que alguien nuevo pueda llegar.
  locationLat Float?
  locationLng Float?
  category    String?
  notes       String?

  status       SupplierStatus @default(PENDING)
  rejectReason String?

  // Quién lo propuso y en qué área estaba en ese momento — se guarda aparte del
  // usuario para que la aprobación siga funcionando aunque luego se elimine o se
  // cambie de área a quien lo creó. Null cuando lo crea el admin directamente.
  createdById     String?
  createdBy       User?   @relation("SupplierCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdByDeptId String?

  approvedById String?
  approvedBy   User?     @relation("SupplierApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contacts SupplierContact[]
  channels SupplierChannel[]

  @@index([status])
  @@index([createdByDeptId])
}

model SupplierContact {
  id         String   @id @default(cuid())
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  // Ej. "Asesor Juan", "Ventas" — a quién corresponde este WhatsApp dentro de la empresa
  label    String
  whatsapp String

  @@index([supplierId])
}

// Enlace a otro canal del proveedor (Telegram, Instagram, Facebook, etc.) —
// hacer clic abre el enlace directamente.
model SupplierChannel {
  id         String   @id @default(cuid())
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  // "TELEGRAM" | "INSTAGRAM" | "FACEBOOK" | "OTHER"
  platform String
  url      String

  @@index([supplierId])
}

// Comprobante de pago (PDF o imagen) de un empleado para un mes/año — solo lo
// sube/edita la líder de Finanzas o el admin; cada empleado solo ve el suyo.
model PayStub {
  id     String @id @default(cuid())
  userId String
  user   User   @relation("PayStubOwner", fields: [userId], references: [id], onDelete: Cascade)

  // Área del empleado al momento de subir el comprobante — se guarda aparte
  // para que el filtro por departamento siga funcionando aunque luego cambie
  // de área, igual que Supplier.createdByDeptId.
  deptId String?

  month Int // 1-12
  year  Int

  fileUrl  String
  fileName String

  // Null cuando lo sube el admin directamente (su sesión no tiene un User real).
  uploadedById String?
  uploadedBy   User?   @relation("PayStubUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, month, year])
  @@index([userId])
  @@index([deptId])
}

// Documento privado del admin (procesos, marketing, branding, patentes...)
// guardado en un bucket de Storage privado — no tiene una URL pública. Por
// defecto solo el admin lo ve; se puede compartir con personas puntuales via
// ConfidentialDocumentAccess. Nunca se sirve directo: siempre a través de una
// URL firmada de corta duración generada al momento, y nunca hay botón de
// descarga en la interfaz.
model ConfidentialDocument {
  id       String  @id @default(cuid())
  title    String
  category String? // libre: "Marketing", "Branding", "Patentes", "Procesos"...

  // Ruta dentro del bucket privado de Supabase Storage (no una URL pública).
  storagePath String
  fileName    String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  grants ConfidentialDocumentAccess[]

  @@index([category])
}

// A quién se le compartió un documento confidencial puntual. seenAt queda
// null hasta que esa persona lo abre por primera vez — así el aviso en el
// sidebar refleja shares concretos sin visitar, no solo una fecha de corte.
model ConfidentialDocumentAccess {
  id         String               @id @default(cuid())
  documentId String
  document   ConfidentialDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  userId     String
  user       User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  grantedAt DateTime  @default(now())
  seenAt    DateTime?

  @@unique([documentId, userId])
  @@index([documentId])
  @@index([userId])
}

// Tracks who has already been shown the birthday popup for whom, on which
// calendar day — so it shows exactly once per person per occurrence and
// naturally reappears next year (a new date = a new row). viewerId/
// celebrantId are plain strings, not foreign keys, because the admin isn't a
// real User row — its sentinel id is the literal "admin".
model BirthdayPopupSeen {
  id              String   @id @default(cuid())
  viewerId        String
  celebrantId     String
  celebrationDate DateTime
  seenAt          DateTime @default(now())

  @@unique([viewerId, celebrantId, celebrationDate])
  @@index([viewerId, celebrationDate])
}

// Tasa de devolución general de toda la empresa — un valor por mes, copiado
// a mano de otra plataforma (no se calcula de otros datos). No está atada a
// un departamento; la sube quien lidera Finanzas (o el admin).
model ReturnRateRecord {
  id    String @id @default(cuid())
  // "YYYY-MM", lo que entrega <input type="month">.
  month String @unique
  value Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Catálogo reutilizable de productos para Ruptura de Stock — se crea una vez
// y luego se elige de la lista, en vez de escribirlo de nuevo cada semana.
model StockoutProduct {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  weeks StockoutWeekProduct[]
}

// Marca que un producto tuvo ruptura de stock (no se pudo despachar por
// falta de stock) en una semana puntual. La barra semanal en el gráfico es
// la CANTIDAD de productos distintos marcados esa semana — no una cantidad
// de unidades ni de veces repetido.
model StockoutWeekProduct {
  id        String          @id @default(cuid())
  // Semana ISO "YYYY-Www", igual que WeeklyMetricRecord.
  week      String
  productId String
  product   StockoutProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([week, productId])
  @@index([week])
  @@index([productId])
}

// Explicit "revisé esta semana y no hubo productos sin stock" — separate from
// simply having zero StockoutWeekProduct rows, since silence is ambiguous
// (genuinely nothing to report vs. the leader just forgot to log it). Used by
// the pendientes panel to only clear a week when either a product was
// attached OR this confirmation exists.
model StockoutWeekConfirmation {
  id        String   @id @default(cuid())
  week      String   @unique
  createdAt DateTime @default(now())
}

// Catálogo reutilizable de categorías/motivos de garantía (ej. "Aprobada",
// "Rechazada - producto roto") — se crea una vez y se reutiliza después.
model WarrantyCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  monthCounts WarrantyCategoryMonthCount[]
}

// "Total de garantías ingresadas" ese mes — el denominador para el % del
// Gráfico 1. Independiente de la suma de categorías (puede haber garantías
// aún sin categorizar).
model WarrantyMonthTotal {
  id        String   @id @default(cuid())
  month     String   @unique // "YYYY-MM"
  total     Int
  updatedAt DateTime @updatedAt
}

// Cuántas garantías de una categoría se registraron en un mes puntual. El
// Gráfico 1 (torta mensual) usa el mes más reciente; el Gráfico 2 (torta de
// "motivos que más se repiten") suma estos conteos de los últimos 12 meses
// para ver qué categoría acumula más — no se sube por separado, se calcula.
model WarrantyCategoryMonthCount {
  id         String           @id @default(cuid())
  month      String           // "YYYY-MM"
  categoryId String
  category   WarrantyCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  count      Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([month, categoryId])
  @@index([month])
  @@index([categoryId])
}

/* ---------------- Colaborador Destacado del Mes ---------------- */

// Una evaluación mensual completa: un líder evaluando a un miembro de su
// equipo, o el admin evaluando a un líder. evaluatorId es "admin" (sentinel,
// sin FK, igual que en BirthdayPopupSeen) cuando lo hace el admin.
model MonthlyEvaluation {
  id          String  @id @default(cuid())
  month       String // "YYYY-MM"
  evaluatorId String // User.id o "admin"
  evaluateeId String
  evaluatee   User    @relation(fields: [evaluateeId], references: [id], onDelete: Cascade)
  comment     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  scores MonthlyEvaluationScore[]

  @@unique([month, evaluateeId])
  @@index([month])
  @@index([evaluateeId])
}

// Una fila por cada pregunta que le tocó a esa evaluación (elegidas al azar
// de un banco fijo por pilar — ver src/lib/recognition.ts). pillar +
// questionId identifican la pregunta exacta dentro de ese banco.
model MonthlyEvaluationScore {
  id           String            @id @default(cuid())
  evaluationId String
  evaluation   MonthlyEvaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  pillar       String
  questionId   String
  score        Int // 1-5

  @@unique([evaluationId, questionId])
  @@index([evaluationId])
}

// Resumen liviano de una evaluación — puntaje total + subtotal por cada uno
// de los 7 pilares, SIN el detalle de las 28 preguntas ni el comentario. Se
// escribe siempre junto con el MonthlyEvaluation detallado, y a diferencia
// de ese, NUNCA se borra — es lo que alimenta el ranking histórico y las
// gráficas de tendencia para siempre, incluso después de que el detalle
// pregunta-por-pregunta de un mes viejo se purga (ver RETENTION_MONTHS en
// src/lib/recognition.ts). El desempate sigue siendo exacto porque conserva
// los mismos subtotales por pilar que usa rankEvaluations().
model MonthlyEvaluationSummary {
  id          String @id @default(cuid())
  month       String // "YYYY-MM"
  evaluateeId String
  evaluatee   User   @relation(fields: [evaluateeId], references: [id], onDelete: Cascade)

  totalScore          Float
  resultadosScore     Int
  excelenciaScore     Int
  compromisoScore     Int
  colaboracionScore   Int
  clienteScore        Int
  innovacionScore     Int
  liderazgoScore      Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([month, evaluateeId])
  @@index([month])
}

// El podio (1°-3°) de un mes, confirmado por el admin con un clic. Queda
// fijo — no se recalcula en vivo — hasta que se confirme el mes siguiente.
model MonthlyRecognitionResult {
  id          String   @id @default(cuid())
  month       String // "YYYY-MM"
  rank        Int // 1, 2 o 3
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  totalScore  Float
  confirmedAt DateTime @default(now())

  @@unique([month, rank])
  @@index([month])
}

// Mismo patrón que BirthdayPopupSeen — cada popup de celebración (1°, 2° o
// 3° lugar) aparece una sola vez por persona por mes, y se registran por
// separado (uno por rank) para poder mostrarlos en secuencia.
model MonthlyRecognitionPopupSeen {
  id       String   @id @default(cuid())
  viewerId String // User.id o "admin"
  month    String
  rank     Int      @default(1) // 1, 2 o 3
  seenAt   DateTime @default(now())

  @@unique([viewerId, month, rank])
}
