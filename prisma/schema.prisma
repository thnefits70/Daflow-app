// DAFLOW — schema de base de datos
// Ver daflow-especificacion.md para el modelo de negocio completo.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/* ---------------- Configuración global de la plataforma ---------------- */
model PlatformSettings {
  id                String   @id @default("singleton")
  adminPasswordHash String
  adminEmail        String?
  logoUrl           String?
  // Marca de agua opcional (logo + wordmark) mostrada discretamente en la tarjeta de Inicio.
  bannerUrl         String?
  updatedAt         DateTime @updatedAt
}

// Token temporal para el flujo de "olvidé mi contraseña" del administrador
model PasswordResetToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
}

/* ---------------- Áreas del negocio ---------------- */
model Department {
  id         String   @id @default(cuid())
  name       String
  code       String   @unique
  order      Int      @default(0)
  // Áreas especiales (ej. proyectos confidenciales) se anclan aparte en el menú,
  // no se mezclan con la lista arrastrable de áreas normales del negocio.
  isSpecial  Boolean  @default(false)
  // Habilita la pestaña de KPIs financieros (ROI, ventas y ganancia mensual) para esta área.
  trackKpis  Boolean  @default(false)
  // Habilita el registro semanal (ej. pedidos despachados) que se muestra en el Inicio para todos.
  trackWeeklyMetric Boolean @default(false)
  // Habilita la bitácora de feedback semanal (reunión admin-líder): problemas y plan de acción.
  // Solo el admin puede escribir en ella; el área solo puede verla.
  trackWeeklyReview Boolean @default(false)
  createdAt  DateTime @default(now())

  users        User[]
  processes    Process[]
  documents    Document[]
  exams        Exam[]
  leaders      User[]      @relation("DeptLeader")
  positions    Position[]
  financeKpis  FinanceKpiRecord[]
  weeklyMetrics WeeklyMetricRecord[]
  weeklyReviews WeeklyReviewRecord[]

  @@index([order])
}

// Catálogo de puestos/cargos que el admin arma por área, para elegir al dar de alta a alguien
model Position {
  id     String     @id @default(cuid())
  deptId String
  dept   Department @relation(fields: [deptId], references: [id], onDelete: Cascade)
  name   String

  @@unique([deptId, name])
  @@index([deptId])
}

/* ---------------- Personas (nómina + acceso) ---------------- */
model User {
  id           String   @id @default(cuid())
  name         String
  username     String   @unique
  passwordHash String
  deptId       String?
  department   Department? @relation(fields: [deptId], references: [id], onDelete: SetNull)

  photoUrl  String?
  position  String?
  email     String?
  phone     String?
  startDate DateTime?
  skills    String[] @default([])
  cvUrl     String?
  cvName    String?

  isLeader    Boolean     @default(false)
  leadsDeptId String?
  leadsDept   Department? @relation("DeptLeader", fields: [leadsDeptId], references: [id], onDelete: SetNull)

  // Puede crear/editar documentos en "Leyes y Reglamentos" (visibles para toda la empresa), pero no eliminarlos.
  canManageLaws Boolean @default(false)

  // Puede proponer proveedores nuevos (quedan "Pendiente" hasta que su líder los apruebe). No puede editar ni eliminar.
  canAddSuppliers Boolean @default(false)

  // Última vez que este usuario (como líder) revisó el Feedback semanal de su área — usado para el
  // contador de "sin leer" en el sidebar. Null = nunca lo ha visto.
  lastSeenFeedbackAt DateTime?

  // Última vez que este usuario revisó sus propios roles de pago — usado para el
  // contador de "sin leer" en el sidebar. Null = nunca lo ha visto.
  lastSeenPayStubAt DateTime?

  snoozeUntil DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  examScores    ExamScore[]
  milestones    Milestone[]
  ackUpdates    UserAckUpdate[]
  suppliersCreated  Supplier[] @relation("SupplierCreatedBy")
  suppliersApproved Supplier[] @relation("SupplierApprovedBy")
  payStubs         PayStub[] @relation("PayStubOwner")
  payStubsUploaded PayStub[] @relation("PayStubUploadedBy")
  confidentialAccess ConfidentialDocumentAccess[]

  @@index([deptId])
  @@index([leadsDeptId])
}

model Milestone {
  id     String   @id @default(cuid())
  userId String
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title  String
  note   String?
  date   DateTime @default(now())

  @@index([userId])
}

/* ---------------- Procesos (flujograma + checklist) ---------------- */
model Process {
  id          String  @id @default(cuid())
  deptId      String
  department  Department @relation(fields: [deptId], references: [id], onDelete: Cascade)
  title       String
  description String  @default("")
  sketchUrl   String?
  sketchName  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  flowSteps      FlowStep[]
  checklistItems ChecklistItem[]
  updates        ProcessUpdate[]

  @@index([deptId])
}

enum FlowStepType {
  START
  END
  PROCESS
  DECISION
  IO
  SUBPROCESS
  DOCUMENT
  PREPARE
  STORAGE
  CONNECTOR
  CHECKLIST
}

model FlowStep {
  id        String       @id @default(cuid())
  processId String
  process   Process      @relation(fields: [processId], references: [id], onDelete: Cascade)
  order     Int          @default(0)
  type      FlowStepType @default(PROCESS)
  label     String
  detail    String       @default("")

  // Solo para type = DOCUMENT: PDF adjunto al bloque
  fileUrl  String?
  fileName String?

  // React Flow canvas position, saved so the editor restores exact layout
  positionX Float @default(0)
  positionY Float @default(0)

  branches        FlowBranch[]            @relation("StepBranches")
  incomingBranch  FlowBranch[]            @relation("StepTarget")
  checklistItems  FlowStepChecklistItem[]

  @@index([processId])
}

// Solo para type = CHECKLIST: puntos de verificación propios de ese bloque del flujo
model FlowStepChecklistItem {
  id     String   @id @default(cuid())
  stepId String
  step   FlowStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
  text   String
  order  Int      @default(0)

  @@index([stepId])
}

model FlowBranch {
  id           String   @id @default(cuid())
  stepId       String
  step         FlowStep @relation("StepBranches", fields: [stepId], references: [id], onDelete: Cascade)
  label        String   @default("")
  targetStepId String?
  targetStep   FlowStep? @relation("StepTarget", fields: [targetStepId], references: [id], onDelete: SetNull)

  // Qué lado del símbolo se usó para dibujar la conexión (top/right/bottom/left)
  sourceHandle String?
  targetHandle String?

  @@index([stepId])
}

model ChecklistItem {
  id        String  @id @default(cuid())
  processId String
  process   Process @relation(fields: [processId], references: [id], onDelete: Cascade)
  text      String
  order     Int     @default(0)

  @@index([processId])
}

model ProcessUpdate {
  id        String   @id @default(cuid())
  processId String
  process   Process  @relation(fields: [processId], references: [id], onDelete: Cascade)
  // Qué cambió, para el historial visible del proceso — obligatorio al notificar.
  note      String   @default("")
  createdAt DateTime @default(now())

  acks UserAckUpdate[]

  @@index([processId])
}

model UserAckUpdate {
  userId   String
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  updateId String
  update   ProcessUpdate @relation(fields: [updateId], references: [id], onDelete: Cascade)
  ackedAt  DateTime      @default(now())

  @@id([userId, updateId])
}

/* ---------------- Documentos (por área, y Leyes y Reglamentos con deptId nulo) ---------------- */
model Document {
  id        String      @id @default(cuid())
  deptId    String?
  department Department? @relation(fields: [deptId], references: [id], onDelete: Cascade)
  isLaw     Boolean     @default(false)
  title     String
  content   String      @default("")
  link      String      @default("")
  fileUrl   String?
  fileName  String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([deptId])
  @@index([isLaw])
}

/* ---------------- Exámenes ---------------- */
model Exam {
  id        String   @id @default(cuid())
  deptId    String
  department Department @relation(fields: [deptId], references: [id], onDelete: Cascade)
  title     String
  createdAt DateTime @default(now())

  questions ExamQuestion[]
  scores    ExamScore[]

  @@index([deptId])
}

model ExamQuestion {
  id           String @id @default(cuid())
  examId       String
  exam         Exam   @relation(fields: [examId], references: [id], onDelete: Cascade)
  text         String
  options      String[]
  correctIndex Int
  order        Int    @default(0)

  @@index([examId])
}

model ExamScore {
  id        String   @id @default(cuid())
  examId    String
  exam      Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userName  String
  score     Int
  total     Int
  createdAt DateTime @default(now())

  @@index([examId])
  @@index([userId])
}

/* ---------------- KPIs financieros (histórico mensual por área) ---------------- */
model FinanceKpiRecord {
  id         String     @id @default(cuid())
  deptId     String
  department Department @relation(fields: [deptId], references: [id], onDelete: Cascade)

  // Mes al que corresponde el registro, formato "YYYY-MM"
  period        String
  roi           Float?
  monthlySales  Float?
  monthlyProfit Float?
  notes         String   @default("")

  // Reporte financiero de respaldo (PDF/imagen), opcional
  fileUrl  String?
  fileName String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([deptId, period])
  @@index([deptId])
}

/* ---------------- Métrica semanal (ej. pedidos despachados de Fulfillment) ---------------- */
model WeeklyMetricRecord {
  id         String     @id @default(cuid())
  deptId     String
  department Department @relation(fields: [deptId], references: [id], onDelete: Cascade)

  // Semana ISO, formato "YYYY-Www" (lo que entrega <input type="week">)
  week  String
  value Int

  // Pedidos que quedaron sin despachar esa semana (opcional), usado para
  // calcular el Fill Rate: value / (value + notDispatched) * 100.
  notDispatched Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([deptId, week])
  @@index([deptId])
}

enum ReviewStatus {
  PENDING
  RESOLVED
  REJECTED
}

/* ---------------- Feedback semanal (reunión admin-líder: problemas y plan de acción) ---------------- */
model WeeklyReviewRecord {
  id         String     @id @default(cuid())
  deptId     String
  department Department @relation(fields: [deptId], references: [id], onDelete: Cascade)

  // Semana ISO, formato "YYYY-Www" (lo que entrega <input type="week">)
  week       String
  problem    String
  actionPlan String
  status     ReviewStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([deptId])
}

enum SupplierStatus {
  PENDING
  APPROVED
  REJECTED
}

/* ---------------- Proveedores (directorio con aprobación del líder) ---------------- */
model Supplier {
  id          String  @id @default(cuid())
  name        String
  location    String?
  // Pin exacto marcado en el mapa (OpenStreetMap), opcional — más confiable que
  // una dirección escrita para que alguien nuevo pueda llegar.
  locationLat Float?
  locationLng Float?
  category    String?
  notes       String?

  status       SupplierStatus @default(PENDING)
  rejectReason String?

  // Quién lo propuso y en qué área estaba en ese momento — se guarda aparte del
  // usuario para que la aprobación siga funcionando aunque luego se elimine o se
  // cambie de área a quien lo creó. Null cuando lo crea el admin directamente.
  createdById     String?
  createdBy       User?   @relation("SupplierCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdByDeptId String?

  approvedById String?
  approvedBy   User?     @relation("SupplierApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contacts SupplierContact[]
  channels SupplierChannel[]

  @@index([status])
  @@index([createdByDeptId])
}

model SupplierContact {
  id         String   @id @default(cuid())
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  // Ej. "Asesor Juan", "Ventas" — a quién corresponde este WhatsApp dentro de la empresa
  label    String
  whatsapp String

  @@index([supplierId])
}

// Enlace a otro canal del proveedor (Telegram, Instagram, Facebook, etc.) —
// hacer clic abre el enlace directamente.
model SupplierChannel {
  id         String   @id @default(cuid())
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  // "TELEGRAM" | "INSTAGRAM" | "FACEBOOK" | "OTHER"
  platform String
  url      String

  @@index([supplierId])
}

// Comprobante de pago (PDF o imagen) de un empleado para un mes/año — solo lo
// sube/edita la líder de Finanzas o el admin; cada empleado solo ve el suyo.
model PayStub {
  id     String @id @default(cuid())
  userId String
  user   User   @relation("PayStubOwner", fields: [userId], references: [id], onDelete: Cascade)

  // Área del empleado al momento de subir el comprobante — se guarda aparte
  // para que el filtro por departamento siga funcionando aunque luego cambie
  // de área, igual que Supplier.createdByDeptId.
  deptId String?

  month Int // 1-12
  year  Int

  fileUrl  String
  fileName String

  // Null cuando lo sube el admin directamente (su sesión no tiene un User real).
  uploadedById String?
  uploadedBy   User?   @relation("PayStubUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, month, year])
  @@index([userId])
  @@index([deptId])
}

// Documento privado del admin (procesos, marketing, branding, patentes...)
// guardado en un bucket de Storage privado — no tiene una URL pública. Por
// defecto solo el admin lo ve; se puede compartir con personas puntuales via
// ConfidentialDocumentAccess. Nunca se sirve directo: siempre a través de una
// URL firmada de corta duración generada al momento, y nunca hay botón de
// descarga en la interfaz.
model ConfidentialDocument {
  id       String  @id @default(cuid())
  title    String
  category String? // libre: "Marketing", "Branding", "Patentes", "Procesos"...

  // Ruta dentro del bucket privado de Supabase Storage (no una URL pública).
  storagePath String
  fileName    String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  grants ConfidentialDocumentAccess[]

  @@index([category])
}

// A quién se le compartió un documento confidencial puntual. seenAt queda
// null hasta que esa persona lo abre por primera vez — así el aviso en el
// sidebar refleja shares concretos sin visitar, no solo una fecha de corte.
model ConfidentialDocumentAccess {
  id         String               @id @default(cuid())
  documentId String
  document   ConfidentialDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  userId     String
  user       User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  grantedAt DateTime  @default(now())
  seenAt    DateTime?

  @@unique([documentId, userId])
  @@index([documentId])
  @@index([userId])
}
